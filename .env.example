# Sarathi Cyberdefense - Environment Configuration Template
# Copy this file to .env and fill in the required credentials before launching.

# ------------------------------------------------------------------------------
# Neo4j Graph Database Configuration
# Supports Neo4j Aura (neo4j+s://) or local developer instances (bolt://)
# ------------------------------------------------------------------------------
NEO4J_URI=neo4j+s://YOUR_AURA_URI
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=YOUR_PASSWORD

# ------------------------------------------------------------------------------
# Gemini Generative AI Configuration
# Required for GenAI RCA reports and structured remediation playbooks.
# ------------------------------------------------------------------------------
GEMINI_API_KEY=YOUR_GEMINI_KEY

# ------------------------------------------------------------------------------
# Service Gateway Configuration
# ------------------------------------------------------------------------------
PORT=8000
